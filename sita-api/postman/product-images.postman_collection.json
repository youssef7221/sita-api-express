{
  "info": {
    "name": "Sita API - Product Images",
    "description": "Ready-to-run requests for Product Image Management endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Upload Product Images",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "images",
              "type": "file",
              "src": ""
            },
            {
              "key": "images",
              "type": "file",
              "src": ""
            },
            {
              "key": "primaryIndex",
              "value": "0",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/products/{{productId}}/images",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "{{productId}}",
            "images"
          ]
        },
        "description": "Uploads multiple images for a product. Set file paths for each images field before sending. If the product has no primary image, keep primaryIndex set."
      },
      "response": []
    },
    {
      "name": "Delete Product Image",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/products/{{productId}}/images/{{imageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "products",
            "{{productId}}",
            "images",
            "{{imageId}}"
          ]
        },
        "description": "Deletes an image by imageId. If it was primary, service auto-assigns the next image as primary."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "imageId",
      "value": "1"
    }
  ]
}
